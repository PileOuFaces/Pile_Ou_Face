{
  "mcpServers": {
    "pile-ou-face": {
      "command": "python3",
      "args": [
        "backends/mcp/server.py",
        "--transport",
        "stdio"
      ],
      "env": {
        "PYTHONUNBUFFERED": "1"
      }
    },
    "gitnexus": {
      "command": "npx",
      "args": [
        "gitnexus",
        "mcp"
      ],
      "env": {}
    },
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp",
        "--output-dir",
        "../.playwright-mcp",
        "--output-mode",
        "file"
      ],
      "env": {}
    }
  }
}
