{
  "decompilers": {
    "angr": {
      "label": "Angr",
      "detect": "python3",
      "command": [
        "/opt/pof-venv/bin/python3", "/opt/pof/decompile.py",
        "--binary", "{binary}",
        "--addr", "{addr}"
      ],
      "full_command": [
        "/opt/pof-venv/bin/python3", "/opt/pof/decompile.py",
        "--binary", "{binary}",
        "--full"
      ],
      "output_format": "json",
      "timeout": 180
    }
  }
}
