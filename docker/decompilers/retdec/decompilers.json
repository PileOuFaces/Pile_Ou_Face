{
  "decompilers": {
    "retdec": {
      "label": "RetDec",
      "detect": "retdec-decompiler",
      "command": [
        "retdec-decompiler",
        "--select-decode-only",
        "--select-functions", "{func_name}",
        "-o", "{out}",
        "{binary}"
      ],
      "fallback_command": [
        "retdec-decompiler",
        "-o", "{out}",
        "{binary}"
      ],
      "full_command": [
        "retdec-decompiler",
        "-o", "{out}",
        "{binary}"
      ],
      "output_format": "c",
      "timeout": 120,
      "docker_platform": "linux/amd64"
    }
  }
}
